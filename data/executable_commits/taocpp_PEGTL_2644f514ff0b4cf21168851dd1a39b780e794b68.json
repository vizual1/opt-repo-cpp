    "commit_info": {
        "old_sha": "268f23e93d297587c941aef63a1e1be052c26af0",
        "new_sha": "2644f514ff0b4cf21168851dd1a39b780e794b68",
        "commit_message": [
            "Speedup, fixes #246"
        ],
        "commit_date": "2020-12-19T15:41:35+00:00",
        "patch": [
            "--- include/tao/pegtl/contrib/parse_tree.hpp\n@@ -67,7 +67,8 @@ namespace TAO_PEGTL_NAMESPACE::parse_tree\n       template< typename U >\n       [[nodiscard]] bool is_type() const noexcept\n       {\n-         return type == demangle< U >();\n+         const auto u = demangle< U >();\n+         return ( ( type.data() == u.data() ) && ( type.size() == u.size() ) ) || ( type == u );\n       }\n \n       template< typename U >"
        ],
        "files_changed": [
            {
                "filename": "include/tao/pegtl/contrib/parse_tree.hpp",
                "status": "modified",
                "additions": 2,
                "deletions": 1,
                "changes": 3,
                "patch": "@@ -67,7 +67,8 @@ namespace TAO_PEGTL_NAMESPACE::parse_tree\n       template< typename U >\n       [[nodiscard]] bool is_type() const noexcept\n       {\n-         return type == demangle< U >();\n+         const auto u = demangle< U >();\n+         return ( ( type.data() == u.data() ) && ( type.size() == u.size() ) ) || ( type == u );\n       }\n \n       template< typename U >"
            }
        ],
        "lines_added": 2,
        "lines_removed": 1
    },
    "issues": [],
    "pull_requests": [
        {
            "number": 246,
            "url": "https://github.com/taocpp/PEGTL/pull/246",
            "title": "parse_tree::basic_node check hash_code() before demangled string",
            "body": "typeid().hash_code() guarantees the same type will have the same\r\nhash_code. Since it's fixed size (size_t) and much faster/simpler to\r\ncompare, use it in `is_type()`.\r\n\r\nHowever, different types can have the same hash_code(). It is not\r\ncommon, but is possible, then we must compare the strings afterwards.\r\n\r\nCloses: #244",
            "merged_at": null
        }
    ],
