    "commit_info": {
        "old_sha": "1d6b36e850a4753f7700dc5247598a6d11c8b4f7",
        "new_sha": "50ede25128481330fce6f3bbbcebaede9374c9bb",
        "commit_message": [
            "speed up parsesectionkeyword()\n\n- convert given string to lower case once\n- keywords to compare with are already lowercase"
        ],
        "commit_date": "2022-07-19T13:36:18+00:00",
        "patch": [
            "--- extern/filereaderlp/reader.cpp\n@@ -10,6 +10,7 @@\n #include <memory>\r\n #include <vector>\r\n #include <array>\r\n+#include <algorithm>\r\n \r\n #include \"def.hpp\"\r\n \r\n@@ -220,29 +221,21 @@ Model readinstance(std::string filename) {\n    return reader.read();\r\n }\r\n \r\n-static\r\n-bool isstrequalnocase(const std::string str1, const std::string str2) {\r\n-   size_t len = str1.size();\r\n-    if (str2.size() != len)\r\n-        return false;\r\n-    for (size_t i = 0; i < len; ++i)\r\n-        if (tolower(str1[i]) != tolower(str2[i]))\r\n-            return false;\r\n-    return true;\r\n-}\r\n-\r\n static\r\n bool iskeyword(const std::string str, const std::string* keywords, const int nkeywords) {\r\n    for (int i=0; i<nkeywords; i++) {\r\n-      if (isstrequalnocase(str, keywords[i])) {\r\n+      if (str == keywords[i]) {\r\n          return true;\r\n       }\r\n    }\r\n    return false;\r\n }\r\n \r\n static\r\n-LpSectionKeyword parsesectionkeyword(const std::string& str) {\r\n+LpSectionKeyword parsesectionkeyword(std::string str) {\r\n+   std::transform(str.begin(), str.end(), str.begin(),\r\n+      [](unsigned char c) { return std::tolower(c); });\r\n+\r\n    if (iskeyword(str, LP_KEYWORD_MIN, LP_KEYWORD_MIN_N)) {\r\n       return LpSectionKeyword::OBJMIN;\r\n    }\r"
        ],
        "files_changed": [
            {
                "filename": "extern/filereaderlp/reader.cpp",
                "status": "modified",
                "additions": 6,
                "deletions": 13,
                "changes": 19,
                "patch": "@@ -10,6 +10,7 @@\n #include <memory>\r\n #include <vector>\r\n #include <array>\r\n+#include <algorithm>\r\n \r\n #include \"def.hpp\"\r\n \r\n@@ -220,29 +221,21 @@ Model readinstance(std::string filename) {\n    return reader.read();\r\n }\r\n \r\n-static\r\n-bool isstrequalnocase(const std::string str1, const std::string str2) {\r\n-   size_t len = str1.size();\r\n-    if (str2.size() != len)\r\n-        return false;\r\n-    for (size_t i = 0; i < len; ++i)\r\n-        if (tolower(str1[i]) != tolower(str2[i]))\r\n-            return false;\r\n-    return true;\r\n-}\r\n-\r\n static\r\n bool iskeyword(const std::string str, const std::string* keywords, const int nkeywords) {\r\n    for (int i=0; i<nkeywords; i++) {\r\n-      if (isstrequalnocase(str, keywords[i])) {\r\n+      if (str == keywords[i]) {\r\n          return true;\r\n       }\r\n    }\r\n    return false;\r\n }\r\n \r\n static\r\n-LpSectionKeyword parsesectionkeyword(const std::string& str) {\r\n+LpSectionKeyword parsesectionkeyword(std::string str) {\r\n+   std::transform(str.begin(), str.end(), str.begin(),\r\n+      [](unsigned char c) { return std::tolower(c); });\r\n+\r\n    if (iskeyword(str, LP_KEYWORD_MIN, LP_KEYWORD_MIN_N)) {\r\n       return LpSectionKeyword::OBJMIN;\r\n    }\r"
            }
        ],
