        "commit_message": [
            "feat(math): enable SSE4 convert instruction usage\n\nMinor win, saves 1-2ns"
        ],
        "commit_date": "2025-08-08T03:05:17+00:00",
        "patch": [
            "--- includes/acl/math/vector4_packing.h\n@@ -802,7 +802,7 @@ namespace acl\n #elif defined(RTM_SSE2_INTRINSICS)\n \t\t__m128i x8y8z8 = _mm_loadu_si128((const __m128i*)vector_data);\n \n-\t#if defined(RTM_SSE4_INTRINSICS) && 0\t// TODO: Profile and test this\n+\t#if defined(RTM_SSE4_INTRINSICS)\n \t\t__m128i x32y32z32 = _mm_cvtepu8_epi32(x8y8z8);\n \t#else\n \t\t__m128i zero = _mm_setzero_si128();"
        ],
        "files_changed": [
            {
                "filename": "includes/acl/math/vector4_packing.h",
                "status": "modified",
                "additions": 1,
                "deletions": 1,
                "changes": 2,
                "patch": "@@ -802,7 +802,7 @@ namespace acl\n #elif defined(RTM_SSE2_INTRINSICS)\n \t\t__m128i x8y8z8 = _mm_loadu_si128((const __m128i*)vector_data);\n \n-\t#if defined(RTM_SSE4_INTRINSICS) && 0\t// TODO: Profile and test this\n+\t#if defined(RTM_SSE4_INTRINSICS)\n \t\t__m128i x32y32z32 = _mm_cvtepu8_epi32(x8y8z8);\n \t#else\n \t\t__m128i zero = _mm_setzero_si128();"
