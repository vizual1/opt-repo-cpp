    "commit_info": {
        "old_sha": "6d29932c5ade23a96f3949d6dc1ca1e6ebadc743",
        "new_sha": "31cde9f231b1173486b016bea655f2cbe9e1d0b8",
        "commit_message": [
            "Performance fix: Divide the SAH cost by the root node area\n- This improves the speed of the parallel reinsertion optimization"
        ],
        "commit_date": "2020-04-27T12:41:51+00:00",
        "patch": [
            "--- include/bvh/parallel_reinsertion_optimizer.hpp\n@@ -17,7 +17,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n     using Scalar    = typename Bvh::ScalarType;\n     using Insertion = std::pair<size_t, Scalar>;\n \n-    using SahBasedAlgorithm<Bvh>::cost;\n+    using SahBasedAlgorithm<Bvh>::compute_cost;\n \n     Bvh& bvh;\n     std::unique_ptr<size_t[]> parents;\n@@ -159,7 +159,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n         auto locks = std::make_unique<std::atomic<int64_t>[]>(bvh.node_count);\n         auto outs  = std::make_unique<Insertion[]>(bvh.node_count);\n \n-        auto old_cost = cost(bvh);\n+        auto old_cost = compute_cost(bvh);\n         for (size_t iteration = 0; ; ++iteration) {\n             size_t first_node = iteration % u + 1;\n \n@@ -222,7 +222,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n             // Compare the old SAH cost to the new one and decrease the number\n             // of nodes that are ignored during the optimization if the change\n             // in cost is below the threshold.\n-            auto new_cost = cost(bvh);\n+            auto new_cost = compute_cost(bvh);\n             if (std::abs(new_cost - old_cost) <= threshold || iteration >= u) {\n                 if (u <= 1)\n                     break;\n--- include/bvh/sah_based_algorithm.hpp\n@@ -18,7 +18,7 @@ class SahBasedAlgorithm {\n protected:\n     ~SahBasedAlgorithm() {}\n \n-    Scalar cost(const Bvh& bvh) const {\n+    Scalar compute_cost(const Bvh& bvh) const {\n         // Compute the SAH cost for the entire BVH\n         Scalar cost(0);\n         #pragma omp parallel for reduction(+: cost)\n@@ -28,7 +28,7 @@ class SahBasedAlgorithm {\n             else\n                 cost += traversal_cost * bvh.nodes[i].bounding_box_proxy().half_area();\n         }\n-        return cost;\n+        return cost / bvh.nodes[0].bounding_box_proxy().half_area();\n     }\n };\n "
        ],
        "files_changed": [
            {
                "filename": "include/bvh/parallel_reinsertion_optimizer.hpp",
                "status": "modified",
                "additions": 3,
                "deletions": 3,
                "changes": 6,
                "patch": "@@ -17,7 +17,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n     using Scalar    = typename Bvh::ScalarType;\n     using Insertion = std::pair<size_t, Scalar>;\n \n-    using SahBasedAlgorithm<Bvh>::cost;\n+    using SahBasedAlgorithm<Bvh>::compute_cost;\n \n     Bvh& bvh;\n     std::unique_ptr<size_t[]> parents;\n@@ -159,7 +159,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n         auto locks = std::make_unique<std::atomic<int64_t>[]>(bvh.node_count);\n         auto outs  = std::make_unique<Insertion[]>(bvh.node_count);\n \n-        auto old_cost = cost(bvh);\n+        auto old_cost = compute_cost(bvh);\n         for (size_t iteration = 0; ; ++iteration) {\n             size_t first_node = iteration % u + 1;\n \n@@ -222,7 +222,7 @@ class ParallelReinsertionOptimizer : public SahBasedAlgorithm<Bvh> {\n             // Compare the old SAH cost to the new one and decrease the number\n             // of nodes that are ignored during the optimization if the change\n             // in cost is below the threshold.\n-            auto new_cost = cost(bvh);\n+            auto new_cost = compute_cost(bvh);\n             if (std::abs(new_cost - old_cost) <= threshold || iteration >= u) {\n                 if (u <= 1)\n                     break;"
            },
            {
                "filename": "include/bvh/sah_based_algorithm.hpp",
                "status": "modified",
                "additions": 2,
                "deletions": 2,
                "changes": 4,
                "patch": "@@ -18,7 +18,7 @@ class SahBasedAlgorithm {\n protected:\n     ~SahBasedAlgorithm() {}\n \n-    Scalar cost(const Bvh& bvh) const {\n+    Scalar compute_cost(const Bvh& bvh) const {\n         // Compute the SAH cost for the entire BVH\n         Scalar cost(0);\n         #pragma omp parallel for reduction(+: cost)\n@@ -28,7 +28,7 @@ class SahBasedAlgorithm {\n             else\n                 cost += traversal_cost * bvh.nodes[i].bounding_box_proxy().half_area();\n         }\n-        return cost;\n+        return cost / bvh.nodes[0].bounding_box_proxy().half_area();\n     }\n };\n "
            }
        ],
