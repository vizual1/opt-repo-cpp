    "commit_info": {
        "old_sha": "1cb5b909a1f240029bceefeb823ec318103034a2",
        "new_sha": "a67c41d6904a6f81ec70bfe1dd575f0d69ccc287",
        "commit_message": [
            "fix(compression): force inline SOA functions\n\nThey have too many arguments and return values via references\nwhich leads to very poor codegen. SOA code in general puts a lot\nof pressure on registers and we often run our with SSE.\nAssume that with SOA, we always want to inline for optimal codegen."
        ],
        "commit_date": "2025-03-27T03:36:29+00:00",
        "patch": [
