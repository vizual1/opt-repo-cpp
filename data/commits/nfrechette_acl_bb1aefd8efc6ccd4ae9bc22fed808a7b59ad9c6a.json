        "commit_message": [
            "fix(compression): add SOA qvv mul without scale\n\nOn ARM64, this saves 8 instructions.\nWithout scale, AoS at 146 and SoA at 94."
        ],
        "commit_date": "2025-03-27T03:44:50+00:00",
